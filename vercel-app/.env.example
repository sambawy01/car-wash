# Cal.com v2 API (booking calendar)
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com/v2
NEXT_PUBLIC_CALCOM_EVENT_TYPE_ID=

# Owner booking-review page (/admin?key=<token>). Generate with:
#   openssl rand -hex 32
ADMIN_TOKEN=

# Ollama Cloud (AI concierge). Leave OLLAMA_API_KEY empty in local dev
# to use a local ollama at http://localhost:11434.
OLLAMA_API_KEY=
OLLAMA_MODEL=deepseek-v4-flash:cloud

# Cal.com webhook -> /api/cal/webhook (HMAC-SHA256 signature secret).
# Generate with: openssl rand -hex 32, then run scripts/register-webhook.mjs
CAL_WEBHOOK_SECRET=

# Booking-request notification emails (Resend, https://resend.com).
# When RESEND_API_KEY is unset the webhook logs the email and no-ops.
RESEND_API_KEY=
NOTIFY_EMAIL=info@eliteecocarwash.com

# Vercel Cron auth for /api/cron/daily-brief (8am-Cairo owner brief).
# When set on the Vercel project, Vercel sends "Authorization: Bearer <secret>"
# with every cron invocation; the route rejects everything else. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# Eco — Elite Eco Car Wash team's Telegram assistant (/api/telegram/webhook).
# Create the bot with @BotFather (/newbot); without a token the webhook
# route answers 501 and the daily-brief Telegram push no-ops.
TELEGRAM_BOT_TOKEN=

# Webhook authenticity secret: Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header on every update; the route fails
# closed without a match. Generate with:
#   openssl rand -hex 32
# then run scripts/setup-telegram.mjs to register the webhook.
TELEGRAM_WEBHOOK_SECRET=
